{
  "name": "@solana/idl",
  "version": "0.1.2",
  "description": "Fetch and reconstruct Solana program IDLs from on-chain Anchor and Program Metadata (PMP) accounts.",
  "keywords": [
    "anchor",
    "idl",
    "kit",
    "on-chain",
    "pmp",
    "program-metadata",
    "solana"
  ],
  "homepage": "https://github.com/solana-foundation/idl#readme",
  "bugs": {
    "url": "https://github.com/solana-foundation/idl/issues"
  },
  "license": "MIT",
  "author": "Solana Foundation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solana-foundation/idl.git"
  },
  "bin": {
    "idl": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup && tsc --project tsconfig.build.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsx src/cli.ts",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint && oxfmt --check",
    "lint:fix": "oxlint --fix && oxfmt",
    "test": "vitest run",
    "test:integration": "vitest run __tests__/integration",
    "record:fixtures": "tsx __tests__/fixtures/record.ts",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@solana-program/program-metadata": "^0.5.1",
    "commander": "^13.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@solana-config/oxc": "^0.1.1",
    "@solana/kit": "^6.8.0",
    "@types/node": "^22.0.0",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "oxlint-tsgolint": "^0.22.1",
    "tsup": "^8.5.1",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@solana/kit": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.4.1"
}
